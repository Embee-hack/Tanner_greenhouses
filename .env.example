# Backend configuration
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
JWT_SECRET=replace-with-a-long-random-secret
JWT_TTL=30d
PORT=3001

# Allowed browser origin(s) for CORS (comma-separated)
CLIENT_ORIGIN=http://localhost:5173

# Public URL used to generate upload links (optional in local dev)
PUBLIC_BASE_URL=

# Upcoming event reminder emails (Gmail SMTP)
EVENT_REMINDER_ENABLED=false
EVENT_REMINDER_LOOKAHEAD_HOURS=24
EVENT_REMINDER_CHECK_INTERVAL_MINUTES=15
EVENT_REMINDER_TIMEZONE=Africa/Lagos

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=yourgmail@gmail.com
